{
    "include": ["src"],
    "compilerOptions": {
        "module": "ESNext",
        "target": "ESNext",
        "moduleResolution": "node",
        "jsx": "preserve",

        "noEmit": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,

        "types": ["node", "snowpack-env"],
        "outDir": "build"
    }
}
